# Copia questo file in .env.local e compila i valori per lo sviluppo locale.
# Questi valori vengono usati da Vite in fase di build (import.meta.env.VITE_*).
# In produzione (container) vengono sovrascritti a runtime tramite entrypoint.sh.

VITE_APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=xxxx;IngestionEndpoint=https://...
VITE_API_BASE_URL=http://localhost:8080

