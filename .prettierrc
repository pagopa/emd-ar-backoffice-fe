{
  "printWidth": 100,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "es5",
  "plugins": ["@trivago/prettier-plugin-sort-imports"],
  "importOrder": [
    "^react$",
    "<THIRD_PARTY_MODULES>",
    "^../../components/(.*)$",
    "^../../redux/(.*)$",
    "^../../api/(.*)$",
    "^../../utils/(.*)$",
    "^../../theme/(.*)$",
    "^../../config$",
    "^../../routes$",
    "^../../types/(.*)$"
  ],
  "importOrderSeparation": true,
  "importOrderSortSpecifiers": true,
  "importOrderParserPlugins": ["typescript", "jsx"]
}